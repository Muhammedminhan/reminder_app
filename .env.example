# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=notifyhub
DB_USER=notifyhub
DB_PASSWORD=replace-with-secure-password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OAuth credentials (rotate if ever committed to git) ───────────────────────
OAUTH_CLIENT_ID=replace-with-your-oauth-client-id
OAUTH_CLIENT_SECRET=replace-with-your-oauth-client-secret

# ── Django superuser (only used on first deploy / fresh DB) ───────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourcompany.com
DJANGO_SUPERUSER_PASSWORD=replace-with-strong-password

# ── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=replace-with-sendgrid-key

# ── Google Cloud (production) ─────────────────────────────────────────────────
# GCS_BUCKET_NAME=notifyhub-media-prod   # leave blank for local dev (uses local filesystem)
# GOOGLE_CLOUD_PROJECT=your-gcp-project

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ── Security (production) ─────────────────────────────────────────────────────
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
