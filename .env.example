# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=notifyhub
DB_USER=notifyhub
DB_PASSWORD=replace-with-secure-password
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OAuth credentials ─────────────────────────────────────────────────────────
# The frontend app is CLIENT_PUBLIC — it has no secret. Only the client_id is
# needed on both the server (to register the app) and the frontend (VITE_CLIENT_ID).
# NEVER set OAUTH_CLIENT_SECRET in production; PUBLIC clients don't use one.
OAUTH_CLIENT_ID=replace-with-your-oauth-client-id
# VITE_CLIENT_ID must match OAUTH_CLIENT_ID — used by the frontend at build time.
VITE_CLIENT_ID=replace-with-your-oauth-client-id
VITE_API_BASE=http://localhost:8000

# ── Django superuser (only used on first deploy / fresh DB) ───────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourcompany.com
DJANGO_SUPERUSER_PASSWORD=replace-with-strong-password

# ── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=replace-with-sendgrid-key

# REQUIRED: must match a SendGrid-authenticated sender domain.
# Go to SendGrid → Settings → Sender Authentication and verify this domain.
# If not set, all system emails (password reset, DNS instructions, etc.) will
# be sent from notifications@notifyhub.app which SendGrid will reject unless
# that domain is authenticated on your account.
DEFAULT_SENDER_EMAIL=notifications@yourdomain.com
DEFAULT_SENDER_NAME=NotifyHub
DEFAULT_FROM_EMAIL=notifications@yourdomain.com

# Admin alert emails (high volume warnings, system alerts)
ADMIN_EMAIL=admin@yourdomain.com

# ── Google Cloud (production) ─────────────────────────────────────────────────
# GCS_BUCKET_NAME=notifyhub-media-prod   # leave blank for local dev (uses local filesystem)
# GOOGLE_CLOUD_PROJECT=your-gcp-project

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
# Connection budget: GUNICORN_WORKERS × GUNICORN_THREADS = DB connections per instance.
# With Cloud SQL db-f1-micro (25 max conns), keep instances × workers × threads < 25.
# Upgrade to db-g1-small (1000 max) or add PgBouncer for production scale.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ── Database connection tuning ────────────────────────────────────────────────
DB_CONN_MAX_AGE=0       # 0 = close after each request (correct for Cloud Run)

# ── Recurring reminder cleanup ────────────────────────────────────────────────
REMINDER_CLEANUP_DAYS=90   # soft-delete sent reminders older than N days

# ── Security (production) ─────────────────────────────────────────────────────
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
