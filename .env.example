# ══════════════════════════════════════════════════════════════════════════════
# NotifyHub — environment variable reference
# Copy this file to .env and fill in every value marked REQUIRED.
# NEVER commit .env to git.
#
# Legend:
#   REQUIRED  — app will not start or a critical feature will break without it
#   OPTIONAL  — has a safe default; override for production
# ══════════════════════════════════════════════════════════════════════════════

# ── Django core ───────────────────────────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=replace-with-a-long-random-string

# OPTIONAL — set False in production (start.sh enforces this)
DEBUG=True

# REQUIRED in production — comma-separated list of allowed hostnames
# e.g. yourdomain.com,www.yourdomain.com,your-cloudrun-url.run.app
ALLOWED_HOSTS=localhost,127.0.0.1

# OPTIONAL — defaults to UTC; set to your local zone e.g. Asia/Dubai
TIME_ZONE=UTC

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# REQUIRED for production — leave blank to use SQLite for local dev
DB_NAME=notifyhub
DB_USER=notifyhub
DB_PASSWORD=replace-with-secure-password
DB_HOST=db
DB_PORT=5432

# OPTIONAL — 0 = close connections after each request (correct for Cloud Run)
DB_CONN_MAX_AGE=0

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED in production — without Redis, rate limiting and MFA tokens are
# per-instance only (broken on multi-instance Cloud Run deployments).
REDIS_URL=redis://redis:6379/0

# ── Webhooks ──────────────────────────────────────────────────────────────────
# REQUIRED — all 4 Cloud Scheduler webhooks return 401 without this.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in your Cloud Scheduler job HTTP headers:
#   X-Webhook-Token: <value>
WEBHOOK_TOKEN=replace-with-a-long-random-string

# ── Google OAuth (social login) ───────────────────────────────────────────────
# REQUIRED — Google login (the only frontend login) fails without these.
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
#   → Create OAuth 2.0 Client ID → Web application
#   → Authorised redirect URIs: ${BACKEND_URL}/google/callback/
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# REQUIRED — used to build the Google OAuth redirect_uri.
# Must match exactly what you registered in the Google Cloud Console.
# Production example: https://your-cloudrun-url.run.app
BACKEND_URL=http://localhost:8000

# REQUIRED — Google callback redirects the user here after login.
# Production example: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:5173

# ── Internal OAuth app (Django OAuth Toolkit) ─────────────────────────────────
# REQUIRED — used by the frontend to authenticate API calls.
# The app uses CLIENT_PUBLIC type — no client_secret is needed or accepted.
# Get/set via Django admin → OAuth2 Provider → Applications.
OAUTH_CLIENT_ID=replace-with-your-oauth-client-id

# VITE_CLIENT_ID must match OAUTH_CLIENT_ID — baked into the JS bundle at build.
VITE_CLIENT_ID=replace-with-your-oauth-client-id
VITE_API_BASE=http://localhost:8000

# ── Django superuser (first deploy / fresh DB only) ───────────────────────────
# OPTIONAL — if unset, no superuser is created automatically (create manually).
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourcompany.com
DJANGO_SUPERUSER_PASSWORD=replace-with-strong-password

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# REQUIRED — password resets, DNS instructions, and alert emails will fail.
SENDGRID_API_KEY=replace-with-sendgrid-key

# REQUIRED — must match a SendGrid-authenticated sender domain.
# Go to SendGrid → Settings → Sender Authentication and verify this domain.
# Without it, all outgoing mail is rejected by SendGrid.
DEFAULT_SENDER_EMAIL=notifications@yourdomain.com
DEFAULT_SENDER_NAME=NotifyHub
DEFAULT_FROM_EMAIL=notifications@yourdomain.com

# OPTIONAL — receives high-volume alert emails
ADMIN_EMAIL=admin@yourdomain.com

# ── Slack ─────────────────────────────────────────────────────────────────────
# OPTIONAL — leave blank to disable Slack notifications (UI shows warning).
# Setup:
#   1. https://api.slack.com/apps → Create New App → From scratch
#   2. OAuth & Permissions → Bot Token Scopes: chat:write, channels:read,
#      users:read, users:read.email, im:write
#   3. Install to Workspace → copy Bot User OAuth Token (starts with xoxb-)
#   4. In each Slack channel: /invite @YourBotName
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_FALLBACK_CHANNEL=#general

# ── Google Cloud Storage (media files) ────────────────────────────────────────
# REQUIRED in production on Cloud Run — without it, uploaded files (profile
# pictures, attachments) are lost on every container restart or redeploy.
# Create a GCS bucket and grant the Cloud Run service account storage.objectAdmin.
GCS_BUCKET_NAME=notifyhub-media-prod

# OPTIONAL — usually inferred from Application Default Credentials on Cloud Run
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── GCP / Cloud Run (domain mapping features) ─────────────────────────────────
# OPTIONAL — only needed if using the custom domain / subdomain mapping feature.
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GCP_CLOUD_RUN_SERVICE=notifyhub

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
# OPTIONAL — SMS delivery is silently skipped when not set.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ── reCAPTCHA ─────────────────────────────────────────────────────────────────
# OPTIONAL — reCAPTCHA is disabled when RECAPTCHA_ENABLED=False (the default).
# RECAPTCHA_ENABLED=False
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ── Rate limiting ─────────────────────────────────────────────────────────────
# OPTIONAL — safe defaults applied when not set.
# RATE_LIMIT_ENABLED=True
# RATE_LIMIT_LOGIN_PER_MINUTE=5
# RATE_LIMIT_SIGNUP_PER_MINUTE=3

# ── Branding / subdomain ──────────────────────────────────────────────────────
# OPTIONAL — controls the subdomain prefix for branded sender domains.
# SUBDOMAIN_BRAND_PREFIX=notifyhub
# USE_SUBDOMAIN_ONLY=True

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
# OPTIONAL — Connection budget: WORKERS × THREADS = DB connections per instance.
# With Cloud SQL db-f1-micro (25 max conns): keep instances × workers × threads < 25.
# Upgrade to db-g1-small (1000 max conns) or add PgBouncer for production scale.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# ── Recurring reminder cleanup ────────────────────────────────────────────────
# OPTIONAL — soft-delete sent reminders older than N days (default: 90)
REMINDER_CLEANUP_DAYS=90

# ── CSRF & CORS (production) ──────────────────────────────────────────────────
# REQUIRED in production — all POST requests return 403 without the correct origins.
# Comma-separated list. Must include your Cloud Run URL and any custom domain.
# e.g. https://your-service.run.app,https://app.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:5173

# REQUIRED in production — all GraphQL / API calls are blocked by CORS without this.
# Must include the URL where the React frontend is served from.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Security (production only) ────────────────────────────────────────────────
# Uncomment all three for production (start.sh sets these automatically when
# DEBUG=False, but explicit values override the auto-detection).
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
